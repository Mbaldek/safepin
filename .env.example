# ── SUPABASE ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=             # Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=            # Supabase Dashboard > Settings > API > service_role (never expose client-side)

# ── MAPBOX ───────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=             # Mapbox Dashboard > Access tokens

# ── STRIPE ───────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=                    # Stripe Dashboard > Developers > API keys
STRIPE_WEBHOOK_SECRET=                # Stripe Dashboard > Webhooks > signing secret (whsec_...)
STRIPE_PRO_MONTHLY_PRICE_ID=          # Stripe Dashboard > Products > plan mensuel > Price ID (price_...)
STRIPE_PRO_ANNUAL_PRICE_ID=           # Stripe Dashboard > Products > plan annuel > Price ID (price_...)

# ── WEB PUSH (VAPID) ────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=         # Generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=                    # Same command as above (private key)
VAPID_SUBJECT=                        # mailto:your@email.com

# ── RESEND (emails) ─────────────────────
RESEND_API_KEY=                       # Resend Dashboard > API Keys

# ── VERIFF (identity verification) ──────
VERIFF_API_KEY=                       # Veriff Dashboard > API keys
VERIFF_SECRET_KEY=                    # Veriff Dashboard > API keys

# ── LIVEKIT (audio/video) ───────────────
LIVEKIT_URL=                          # LiveKit Cloud > Project settings > URL (wss://...)
LIVEKIT_API_KEY=                      # LiveKit Cloud > Project settings > API key
LIVEKIT_API_SECRET=                   # LiveKit Cloud > Project settings > API secret

# ── CRON ─────────────────────────────────
CRON_SECRET=                          # Random string, must match Vercel Cron config

# ── MISC ─────────────────────────────────
NEXT_PUBLIC_SITE_URL=                 # Production URL (e.g. https://safepin-omega.vercel.app)
NEXT_PUBLIC_SUPPORT_USER_ID=          # Supabase user ID for the support/bot account
